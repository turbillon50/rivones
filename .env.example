# ==========================================================================
# Rivones — environment variables
# ==========================================================================
# Copy this file to `.env` and fill in real values for local development.
# In production these come from Replit / Vercel secrets, never .env files.

# --- Database --------------------------------------------------------------
DATABASE_URL=postgres://user:password@localhost:5432/rivones

# --- API server ------------------------------------------------------------
PORT=3000
# Comma-separated list of origins allowed to call the API. The API also
# auto-allows *.rentamerapido.autos and *.vercel.app.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Per-IP per-minute limit for /api/*. Defaults to 240.
RATE_LIMIT_PER_MINUTE=240
# Public origin used for redirect URLs (Stripe Connect onboarding etc.)
PLATFORM_BASE_URL=https://rentamerapido.autos

# --- Authentication (Clerk) ------------------------------------------------
# Backend secret key — never expose to the client.
CLERK_SECRET_KEY=REPLACE_MExxxxxxxx
# Optional: also exposed via VITE_CLERK_PUBLISHABLE_KEY for the frontend.
CLERK_PUBLISHABLE_KEY=REPLACE_MExxxxxxxx
# Frontend (Vite) — production uses VITE_CLERK_LIVE_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=REPLACE_MExxxxxxxx
# VITE_CLERK_LIVE_PUBLISHABLE_KEY=REPLACE_ME

# --- Admin overrides -------------------------------------------------------
# Server-to-server admin key. Required in production. The legacy "autos"
# value still works ONLY when ADMIN_API_KEY is unset (and logs a warning).
ADMIN_API_KEY=change-me-in-production

# Set to "1" to require a verified driver's license before creating bookings.
REQUIRE_LICENSE_VERIFIED=0

# --- Stripe ----------------------------------------------------------------
# Local dev usually pulls these from Replit's connector (see stripeClient.ts).
# Set them explicitly here when running outside Replit.
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_PUBLISHABLE_KEY=REPLACE_ME
VITE_STRIPE_PUBLISHABLE_KEY=REPLACE_ME
# Created in the Stripe dashboard for the /api/stripe/webhook endpoint.
STRIPE_WEBHOOK_SECRET=REPLACE_ME

# --- Email (Resend) --------------------------------------------------------
# When unset, the API silently skips sending emails (handy for tests).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Rivones <hola@rentamerapido.autos>

# --- Google Maps -----------------------------------------------------------
VITE_GOOGLE_MAPS_API_KEY=

# --- Object storage (Replit / GCS) -----------------------------------------
PUBLIC_OBJECT_SEARCH_PATHS=/replit-public/cars,/replit-public/marketing
PRIVATE_OBJECT_DIR=/replit-private/uploads

# --- Observability ---------------------------------------------------------
# Optional. When set, server-side errors are reported to Sentry.
SENTRY_DSN=
VITE_SENTRY_DSN=
