# ==========================================================================
# Rivones — environment variables
# ==========================================================================
# Copy this file to `.env` and fill in real values for local development.
# In production these come from the Vercel project settings ("Environment
# Variables" tab) — never commit real values.

# --- Database (Neon) -------------------------------------------------------
# Use Neon's "Pooled connection" string for serverless (it ends with
# `-pooler.<region>.aws.neon.tech` and routes through PgBouncer).
# Required query param: `sslmode=require`.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxxxx-pooler.us-east-1.aws.neon.tech/rivones?sslmode=require

# --- API server ------------------------------------------------------------
# Only needed for local `pnpm --filter @workspace/api-server dev`. On Vercel
# the function picks its own port.
PORT=3000

# Comma-separated list of full origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Apex production domain — every subdomain is auto-allowed (e.g. set
# "example.com" and CORS allows "www.example.com" + "api.example.com").
CORS_ALLOWED_DOMAIN=

# Per-IP per-minute limit for /api/*. Defaults to 240 when unset.
RATE_LIMIT_PER_MINUTE=240

# Public origin used for redirect URLs (Stripe Connect onboarding, email CTAs).
PLATFORM_BASE_URL=https://www.example.com

# Auto-seed the DB with two demo cars on first cold start. Leave unset in prod.
AUTO_SEED=

# --- Authentication (Clerk) ------------------------------------------------
# Backend secret key — never expose to the client.
CLERK_SECRET_KEY=
# Optional duplicate, only consumed by the API (frontend uses VITE_*).
CLERK_PUBLISHABLE_KEY=

# Frontend (Vite). Test key for local dev; live key wins when on the
# production host.
VITE_CLERK_PUBLISHABLE_KEY=
# VITE_CLERK_LIVE_PUBLISHABLE_KEY=

# Hostname where the live Clerk key should activate. Without this, Vite's
# import.meta.env.PROD flag is used.
# VITE_PRODUCTION_HOST=www.example.com

# --- Admin overrides -------------------------------------------------------
# Server-to-server admin key. REQUIRED in production. Until set, the legacy
# literal "autos" still works (and the API logs a loud warning).
ADMIN_API_KEY=

# Set to "1" to require a verified driver's license before creating bookings.
REQUIRE_LICENSE_VERIFIED=0

# --- Stripe ----------------------------------------------------------------
# Test keys for local dev; switch to live (sk_live_…/pk_live_…) on Vercel.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
# Created in the Stripe dashboard → Developers → Webhooks → "Add endpoint".
# Endpoint URL: https://api.example.com/api/stripe/webhook
# Subscribe to: payment_intent.succeeded, payment_intent.payment_failed, account.updated
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) --------------------------------------------------------
# When unset, the API silently skips sending emails (handy for tests).
RESEND_API_KEY=
# Verified sender. While DNS isn't ready, "onboarding@resend.dev" is fine.
RESEND_FROM_EMAIL=Rivones <onboarding@resend.dev>

# --- Google Maps -----------------------------------------------------------
VITE_GOOGLE_MAPS_API_KEY=

# --- Frontend → API origin -------------------------------------------------
# In dev, Vite proxies /api to VITE_API_PROXY. In prod (Vercel), the frontend
# fetches VITE_API_BASE_URL + /api/*.
VITE_API_PROXY=http://localhost:3000
# VITE_API_BASE_URL=https://api.example.com

# --- Object storage (legacy Replit GCS sidecar) ----------------------------
# These only apply on Replit. On Vercel storage needs to migrate to Vercel
# Blob, S3, or Cloudflare R2 (see DEPLOY.md). Leave blank in production until
# the swap lands.
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# --- Observability (optional) ----------------------------------------------
SENTRY_DSN=
VITE_SENTRY_DSN=
